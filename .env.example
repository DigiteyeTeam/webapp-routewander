# สร้าง API key ได้ที่ https://aistudio.google.com/apikey
# รูปแบบที่รองรับ: AIzaSy... (Standard) หรือ AQ.... (Authorization key ใหม่)
# ใส่ key ในไฟล์ .env (ไม่ใช่ .env.example) แล้วรัน npm run dev
GEMINI_API_KEY=

# โหมดแชท: auto (ค่าเริ่มต้น) | mock | gemini
# auto = ใช้ Gemini ถ้ามี key ถูกต้อง, ไม่มีหรือล้มเหลวจะ fallback เป็น mock
# mock = ใช้ AI สาธิตจากข้อมูลเส้นทางในระบบเท่านั้น
# gemini = บังคับใช้ Gemini (ไม่ fallback)
CHAT_MODE=auto

# โมเดล (ค่าเริ่มต้น: gemini-2.0-flash-lite, gemini-1.5-flash, gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash-lite

# พอร์ต API server (ค่าเริ่มต้น 3001) — Vite proxy ไปที่พอร์ตนี้
# API_PORT=3001
