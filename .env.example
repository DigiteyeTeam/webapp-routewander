# === AI Chat (ทำงานฝั่ง browser โดยตรง — ไม่ต้องรัน API server) ===
# สร้าง API key ได้ที่ https://aistudio.google.com/apikey
GEMINI_API_KEY=

# โหมดแชท: auto (ค่าเริ่มต้น) | mock | gemini
# auto = ใช้ Gemini ถ้ามี key, ไม่มีหรือล้มเหลวจะ fallback เป็น mock
CHAT_MODE=auto

# โมเดล (ไม่บังคับ)
# GEMINI_MODEL=gemini-2.5-flash

# บน Vercel ตั้ง env แล้วกด Redeploy (key ถูกฝังตอน build):
#   GEMINI_API_KEY=...        (Production + Preview)
#   CHAT_MODE=auto            (ตั้งทุก environment ที่ใช้ทดสอบ)
#   GEMINI_MODEL=gemini-2.5-flash  (ไม่บังคับ)
# หมายเหตุ: key ฝังใน JS — เหมาะช่วงทดสอบ | ถ้า key AQ.... ไม่ทำงานบนเว็บ ลองสร้าง Standard key (AIzaSy...)

# === รัน dev ===
# npm run dev   (แค่ Vite port 4000 — ไม่ต้องรัน API server)

# === (ทางเลือก) API server แยก — ไม่จำเป็นสำหรับแชท ===
# npm run dev:api
# API_PORT=3001
